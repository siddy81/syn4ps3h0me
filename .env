# Production environment configuration (used directly by docker compose)
PC_IP=192.168.1.3
RPI_IP=192.168.1.101
INTRANET_DOMAIN=arkham.asylum
TZ=Europe/Berlin


# Pi-hole
PIHOLE_WEBTHEME=default-darker
PIHOLE_DNS_UPSTREAMS=1.1.1.1;1.0.0.1;1.1.1.1;9.9.9.9
PIHOLE_DNSSEC=true
PIHOLE_ADMIN_PASSWORD=admin123
PIHOLE_API_PASSWORD=admin123

# Pi-hole DHCP (optional; disable router DHCP before enabling)
PIHOLE_DHCP_ACTIVE=false
PIHOLE_DHCP_START=192.168.1.2
PIHOLE_DHCP_END=192.168.1.255
PIHOLE_DHCP_ROUTER=192.168.1.1
PIHOLE_DHCP_LEASETIME=24h

# MQTT
MQTT_USER=shelly
MQTT_PASSWORD=123456

# InfluxDB
INFLUXDB_INIT_MODE=setup
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin123
INFLUXDB_ORG=home
INFLUXDB_BUCKET=shelly
INFLUXDB_WRITE_TOKEN=influx-token-123456

# Grafana
GF_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

#caddy

PIHOLE_DOMAIN=nightmaresiddious.arkham.asylum
LEGACY_HOST_IP=192.168.1.101

# Open WebUI
OPEN_WEBUI_PORT=3001
OPEN_WEBUI_ADMIN_EMAIL=admin@localhost
OPEN_WEBUI_ADMIN_PASSWORD=admin123
OPEN_WEBUI_ADMIN_NAME=Admin
OPEN_WEBUI_OLLAMA_BASE_URL=http://127.0.0.1:11434

# end Open WebUI
