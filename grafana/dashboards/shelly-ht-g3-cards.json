        {
          "query": "import \"strings\"\nimport \"math\"\nfrom(bucket: \"shelly\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"shelly_ht\")\n  |> filter(fn: (r) => r._field == \"temperature_c\" or r._field == \"humidity_pct\")\n  |> map(fn: (r) => ({ r with room: strings.trimPrefix(v: strings.split(v: r.topic, t: \"/\")[0], prefix: \"shelly_ht_\") }))\n  |> group(columns: [\"room\", \"_field\"])\n  |> last()\n  |> group()\n  |> pivot(rowKey: [\"room\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({\n      Raum: r.room,\n      Raumtemperatur: r.temperature_c,\n      Raumfeuchtigkeit: r.humidity_pct,\n      Taupunkttemperatur: if r.humidity_pct > 0.0 then (243.12 * (((17.62 * r.temperature_c) / (243.12 + r.temperature_c)) + math.log(x: r.humidity_pct / 100.0))) / (17.62 - (((17.62 * r.temperature_c) / (243.12 + r.temperature_c)) + math.log(x: r.humidity_pct / 100.0))) else float(v: 0.0)\n    }))\n  |> keep(columns: [\"Raum\", \"Raumtemperatur\", \"Raumfeuchtigkeit\", \"Taupunkttemperatur\"])\n  |> sort(columns: [\"Raum\"])",
          "refId": "A"
        }
      ],
