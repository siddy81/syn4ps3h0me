      "targets": [
        {
          "query": "import \"strings\"\n\nbatteryData = from(bucket: \"shelly\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"shelly_ht\" and r._field == \"battery_pct\")\n  |> map(fn: (r) => ({ r with device: strings.trimPrefix(v: strings.split(v: r.topic, t: \"/\")[0], prefix: \"shelly_ht_\") }))\n  |> group(columns: [\"device\"])\n\nfirstValues = batteryData\n  |> first()\n  |> keep(columns: [\"device\", \"_time\", \"_value\"])\n  |> rename(columns: {_time: \"first_time\", _value: \"first_value\"})\n\nlastValues = batteryData\n  |> last()\n  |> keep(columns: [\"device\", \"_time\", \"_value\"])\n  |> rename(columns: {_time: \"last_time\", _value: \"last_value\"})\n\npositiveRecharge = batteryData\n  |> difference(columns: [\"_value\"], nonNegative: false, keepFirst: false)\n  |> map(fn: (r) => ({ r with recharge: if r._value > 0.0 then r._value else 0.0 }))\n  |> group(columns: [\"device\"])\n  |> sum(column: \"recharge\")\n  |> keep(columns: [\"device\", \"recharge\"])\n  |> rename(columns: {recharge: \"recharge_total\"})\n\njoin(tables: {first: firstValues, last: lastValues}, on: [\"device\"])\n  |> join(tables: {recharge: positiveRecharge}, on: [\"device\"])\n  |> map(fn: (r) => {\n    elapsedS = float(v: uint(v: r.last_time) - uint(v: r.first_time)) / 1000000000.0\n    adjustedChange = (r.last_value - r.first_value) - r.recharge_total\n    ratePerSecond = if elapsedS > 0.0 then adjustedChange / elapsedS else 0.0\n    secondsToZero = if ratePerSecond < 0.0 then r.last_value / (-ratePerSecond) else -1.0\n    forecastTime = if secondsToZero > 0.0 then time(v: uint(v: r.last_time) + uint(v: secondsToZero * 1000000000.0)) else r.last_time\n    forecastRaw = string(v: forecastTime)\n    forecast = if secondsToZero > 0.0 then strings.substring(v: forecastRaw, start: 8, end: 10) + \".\" + strings.substring(v: forecastRaw, start: 5, end: 7) + \".\" + strings.substring(v: forecastRaw, start: 0, end: 4) + \" \" + strings.substring(v: forecastRaw, start: 11, end: 16) else \"keine Prognose\"\n\n    return {\n      Name: r.device,\n      \"Batterieladestand (%)\": r.last_value,\n      \"Voraussichtlich leer am\": forecast,\n    }\n  })\n  |> keep(columns: [\"Name\", \"Batterieladestand (%)\", \"Voraussichtlich leer am\"])\n  |> sort(columns: [\"Name\"])\n",
          "refId": "A"
        }
      ],
      "title": "🔋 Batteriestatus & Leer-Prognose je Sensor",
      "type": "table"
